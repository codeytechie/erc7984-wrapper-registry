# Hardhat reads these via `npx hardhat vars set <NAME>` (preferred) or env.
# A funded deployer is only needed to deploy the Lens to a public network.

# 12-word mnemonic for the deployer account (account index 0).
MNEMONIC="test test test test test test test test test test test junk"

# RPC endpoints. Public defaults are baked into hardhat.config.ts; override for
# reliability / higher rate limits.
SEPOLIA_RPC_URL="https://ethereum-sepolia-rpc.publicnode.com"
MAINNET_RPC_URL="https://ethereum-rpc.publicnode.com"

# For `verify:verify` on Etherscan after deploying the Lens.
ETHERSCAN_API_KEY=""
