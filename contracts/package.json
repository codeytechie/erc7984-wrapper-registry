{
  "name": "@cwr/contracts",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "Confidential Wrapper Registry — contracts (WrapperRegistryLens + FHEVM mock harness)",
  "scripts": {
    "clean": "rimraf ./artifacts ./cache ./coverage ./types ./coverage.json ./dist",
    "compile": "cross-env TS_NODE_TRANSPILE_ONLY=true hardhat compile",
    "typechain": "cross-env TS_NODE_TRANSPILE_ONLY=true hardhat typechain",
    "test": "hardhat test",
    "test:sepolia": "hardhat test --network sepolia",
    "coverage": "cross-env SOLIDITY_COVERAGE=true hardhat coverage --testfiles \"test/**/*.ts\"",
    "chain": "hardhat node",
    "deploy:lens:sepolia": "hardhat run scripts/deploy-lens.ts --network sepolia",
    "deploy:lens:mainnet": "hardhat run scripts/deploy-lens.ts --network mainnet",
    "verify:sepolia": "hardhat verify --network sepolia",
    "lint:sol": "solhint \"contracts/**/*.sol\""
  },
  "dependencies": {
    "@fhevm/mock-utils": "^0.4.2",
    "@fhevm/solidity": "^0.11.1",
    "@openzeppelin/confidential-contracts": "^0.5.1",
    "@openzeppelin/contracts": "^5.6.1",
    "encrypted-types": "^0.0.4"
  },
  "devDependencies": {
    "@fhevm/hardhat-plugin": "^0.4.2",
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.0",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.30",
    "@zama-fhe/relayer-sdk": "^0.4.1",
    "chai": "^4.5.0",
    "chai-as-promised": "^8.0.2",
    "cross-env": "^7.0.3",
    "ethers": "^6.16.0",
    "hardhat": "^2.28.6",
    "hardhat-gas-reporter": "^2.3.0",
    "rimraf": "^6.1.3",
    "solhint": "^6.2.1",
    "solidity-coverage": "^0.8.17",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "elliptic": ">=6.6.1",
    "cookie": ">=0.7.0",
    "tar-fs": ">=2.1.2",
    "micromatch": ">=4.0.8"
  }
}
