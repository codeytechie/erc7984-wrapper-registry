# Port to listen on.
PORT=8788

# Private upstream URLs, one per chain: RPC_URL_<chainId> (kept server-side).
# Any chainId works, e.g. 1 (mainnet), 11155111 (sepolia), 8453 (base), 84532 (base sepolia).
RPC_URL_1=https://lb.drpc.org/ogrpc?network=ethereum&dkey=YOUR_DRPC_KEY
RPC_URL_11155111=https://lb.drpc.org/ogrpc?network=sepolia&dkey=YOUR_DRPC_KEY

# Comma-separated browser origins allowed to use the proxy. Empty = allow all.
ALLOWED_ORIGINS=http://localhost:3001
