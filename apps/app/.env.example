# WalletConnect project id (https://cloud.reown.com). Required for WalletConnect.
NEXT_PUBLIC_WC_PROJECT_ID=

# Private RPC proxy (services/rpc-proxy). When set, it is the priority RPC for
# every chain; the values below stay as automatic fallbacks.
NEXT_PUBLIC_RPC_PROXY=http://localhost:8788

# RPCs. Default to public nodes if unset.
NEXT_PUBLIC_SEPOLIA_RPC=https://ethereum-sepolia-rpc.publicnode.com
NEXT_PUBLIC_MAINNET_RPC=https://ethereum-rpc.publicnode.com

# Price oracle service (@cwr/price-oracle). Default local dev port.
NEXT_PUBLIC_PRICE_API=http://localhost:8787
