{
  "name": "erc7984-wrapper-registry",
  "private": true,
  "workspaces": ["sdk", "tools", "apps/*", "services/*"],
  "scripts": {
    "build:sdk": "npm run build -w @cwr/sdk",
    "dev:app": "npm run dev -w @cwr/app",
    "dev:landing": "npm run dev -w @cwr/landing",
    "dev:prices": "npm run dev -w @cwr/price-oracle",
